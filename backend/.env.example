# Flask Configuration
FLASK_CONFIG=development
FLASK_PORT=5000

# Logging
LOG_LEVEL=DEBUG

# CORS Settings
CORS_ORIGINS=*

# Orion Context Broker Configuration
ORION_URL=http://localhost:1026
ORION_FIWARE_SERVICE=smart-retail
ORION_FIWARE_SERVICEPATH=/

# Health Check Timeout (seconds)
HEALTH_CHECK_TIMEOUT=2
