# Project name
COMPOSE_PROJECT_NAME=fiware

# Orion variables
ORION_PORT=1026
ORION_VERSION=4.1.0

# MongoDB variables
MONGO_DB_PORT=27017
MONGO_DB_VERSION=6.0

# Tutorial variables
TUTORIAL_APP_PORT=3002
TUTORIAL_DUMMY_DEVICE_PORT=3001

# Backend defaults
FLASK_CONFIG=development
FLASK_PORT=5000
LOG_LEVEL=DEBUG
CORS_ORIGINS=*
ORION_URL=http://localhost:1026
ORION_FIWARE_SERVICE=smart_retail
ORION_FIWARE_SERVICEPATH=/
HEALTH_CHECK_TIMEOUT=2